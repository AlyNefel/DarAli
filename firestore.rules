rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "aliessoudani412@gmail.com");
    }

    function isEmployee() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'employee']);
    }

    // User profiles
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isAuthenticated() && request.auth.uid == uid);
    }

    // Room Types
    match /roomTypes/{roomTypeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Availability
    match /availability/{availabilityId} {
      allow read: if true;
      allow write: if true; // In a production app, this should be more restricted (e.g., only via server actions or specific logic)
    }

    // Bookings
    match /bookings/{bookingId} {
      allow read: if isEmployee();
      allow create: if true;
      allow update, delete: if isEmployee();
    }

    // Locks
    match /locks/{lockId} {
      allow read, write: if true; // Needed for client-side locking
    }

    // Transactions
    match /transactions/{transactionId} {
      allow read, write: if isAdmin();
    }

    // Room Mappings
    match /roomMappings/{mappingId} {
      allow read: if isEmployee();
      allow write: if isAdmin();
    }
  }
}
