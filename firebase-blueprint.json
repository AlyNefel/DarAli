{
  "entities": {
    "User": {
      "title": "User",
      "description": "System users and employees",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "employee"] },
        "photoURL": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "RoomType": {
      "title": "RoomType",
      "description": "Hotel room categories and pricing",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "totalInventory": { "type": "number" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "baseCapacity": { "type": "number" },
        "maxCapacity": { "type": "number" },
        "icalImportUrl": { "type": "string" }
      },
      "required": ["name", "slug", "totalInventory", "price"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Room reservations",
      "type": "object",
      "properties": {
        "source": { "type": "string", "enum": ["website", "booking", "manual"] },
        "checkIn": { "type": "string", "format": "date-time" },
        "checkOut": { "type": "string", "format": "date-time" },
        "roomTypeId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled", "staying", "completed"] },
        "guestInfo": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string", "format": "email" },
            "phone": { "type": "string" }
          },
          "required": ["name", "email"]
        },
        "totalAmount": { "type": "number" },
        "externalId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["source", "checkIn", "checkOut", "roomTypeId", "status", "guestInfo", "createdAt"]
    },
    "Availability": {
      "title": "Availability",
      "description": "Daily inventory tracking",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date-time" },
        "roomTypeId": { "type": "string" },
        "total": { "type": "number" },
        "booked": { "type": "number" },
        "locked": { "type": "number" },
        "available": { "type": "number" }
      },
      "required": ["date", "roomTypeId", "total", "booked", "locked", "available"]
    },
    "Lock": {
      "title": "Lock",
      "description": "Temporary booking locks",
      "type": "object",
      "properties": {
        "roomTypeId": { "type": "string" },
        "checkIn": { "type": "string", "format": "date-time" },
        "checkOut": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "sessionId": { "type": "string" }
      },
      "required": ["roomTypeId", "checkIn", "checkOut", "expiresAt", "sessionId"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial accounting records",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["income", "expense"] },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "bookingId": { "type": "string" }
      },
      "required": ["type", "amount", "date"]
    },
    "RoomMapping": {
      "title": "RoomMapping",
      "description": "Mappings between internal and external room IDs",
      "type": "object",
      "properties": {
        "internalRoomId": { "type": "string" },
        "provider": { "type": "string" },
        "externalRoomId": { "type": "string" },
        "icalUrl": { "type": "string" }
      },
      "required": ["internalRoomId", "provider"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/roomTypes/{roomTypeId}": { "schema": "RoomType", "description": "Room categories" },
    "/bookings/{bookingId}": { "schema": "Booking", "description": "Reservations" },
    "/availability/{availabilityId}": { "schema": "Availability", "description": "Inventory" },
    "/locks/{lockId}": { "schema": "Lock", "description": "Temporary locks" },
    "/transactions/{transactionId}": { "schema": "Transaction", "description": "Accounting" },
    "/roomMappings/{mappingId}": { "schema": "RoomMapping", "description": "Provider mappings" }
  }
}
