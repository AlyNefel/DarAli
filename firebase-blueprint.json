{
  "entities": {
    "User": {
      "title": "User",
      "description": "System users and employees",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "employee"] },
        "photoURL": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Room": {
      "title": "Room",
      "description": "Hotel room details",
      "type": "object",
      "properties": {
        "number": { "type": "string" },
        "type": { "type": "string", "enum": ["luxury", "deluxe", "standard"] },
        "price": { "type": "number" },
        "status": { "type": "string", "enum": ["available", "occupied", "maintenance"] },
        "images": { "type": "array", "items": { "type": "string" } },
        "description": { "type": "string" }
      },
      "required": ["number", "type", "price", "status"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Room reservations",
      "type": "object",
      "properties": {
        "guestName": { "type": "string" },
        "guestEmail": { "type": "string", "format": "email" },
        "roomId": { "type": "string" },
        "checkIn": { "type": "string", "format": "date-time" },
        "checkOut": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "totalPrice": { "type": "number" },
        "source": { "type": "string" }
      },
      "required": ["guestName", "roomId", "checkIn", "checkOut", "status"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial accounting records",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["income", "expense"] },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "bookingId": { "type": "string" }
      },
      "required": ["type", "amount", "date"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Internal employee chat messages",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "text", "timestamp"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/rooms/{roomId}": { "schema": "Room", "description": "Hotel rooms" },
    "/bookings/{bookingId}": { "schema": "Booking", "description": "Reservations" },
    "/transactions/{transactionId}": { "schema": "Transaction", "description": "Accounting" },
    "/chat/{messageId}": { "schema": "ChatMessage", "description": "Internal chat" }
  }
}
